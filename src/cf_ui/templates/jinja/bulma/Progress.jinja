{#def value=0, max=100, type="primary", label="", extra_class="" #}
<div class="{{ extra_class }}">
  {% if label %}<p class="has-text-centered mb-1">{{ label }}</p>{% endif %}
  <progress class="progress is-{{ type }}"
            value="{{ value }}"
            max="{{ max }}">{{ value }}%</progress>
</div>
