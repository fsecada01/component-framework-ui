{#def name, label, choices=[], selected=[], error="", extra_class="" #}
<div class="field {{ extra_class }}">
  <label class="label">{{ label }}</label>
  <div class="control">
    {% for choice in choices %}
    <label class="checkbox mr-3">
      <input type="checkbox"
             name="{{ name }}"
             value="{{ choice.value }}"
             {% if choice.value in selected %}checked{% endif %}>
      {{ choice.label }}
    </label>
    {% endfor %}
  </div>
  {% if error %}<p class="help is-danger">{{ error }}</p>{% endif %}
</div>
